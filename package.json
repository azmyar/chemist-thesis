{
  "name": "chemist-thesis-lab",
  "private": true,
  "workspaces": [
    "packages/lab-app",
    "packages/lab-server",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently -n lab-app,lab-server -c '#ff6b6b,#a855f7' \"bun run --filter=@chemist/lab-app dev\" \"bun run --filter=@chemist/lab-server dev -- --port 8787\"",
    "dev:app": "bun run --filter=@chemist/lab-app dev",
    "dev:server": "bun run --filter=@chemist/lab-server dev -- --port 8787",
    "build": "bun run --filter=@chemist/lab-app build"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
